@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nhập SĐT - Highlands Coffee</title>

    <style>
        /* Nền trang */
        body.highlands-splash {
            margin: 0;
            padding: 0;
            height: 100vh;
            background-color: #7a1d22;
            background-image: url('/images/bg-highlands.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            position: relative;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

            /* Lớp phủ đen mờ */
            body.highlands-splash::before {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                bottom: 0;
                left: 0;
                background: rgba(0, 0, 0, 0.4);
                z-index: 1;
            }

        .lang-toggle {
            position: absolute;
            top: 25px;
            right: 40px;
            color: white;
            font-weight: bold;
            z-index: 2;
            font-size: 14px;
        }

        .footer-copy {
            position: absolute;
            bottom: 20px;
            right: 40px;
            color: white;
            font-size: 12px;
            z-index: 2;
        }

        /* Hộp đăng nhập */
        .login-overlay-box {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background-color: rgba(162, 131, 99, 0.95);
            padding: 40px 50px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            z-index: 3;
            text-align: center;
            min-width: 350px;
        }

        /* DÒNG HƯỚNG DẪN MỚI THÊM VÀO */
        .instruction-text {
            color: #fceceb; /* Màu trắng ngà cho dịu mắt */
            font-size: 15px;
            margin-bottom: 25px;
            line-height: 1.5;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
        }

        .input-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 30px;
        }

            .input-row label {
                color: white;
                font-weight: bold;
                font-size: 18px;
                cursor: pointer;
            }

            .input-row input {
                background: transparent;
                border: none;
                border-bottom: 2px solid white;
                color: white;
                font-size: 18px;
                width: 150px;
                outline: none;
                text-align: center;
                padding: 5px;
                font-weight: bold;
                transition: border-color 0.3s;
            }

                .input-row input::placeholder {
                    color: rgba(255, 255, 255, 0.5);
                    font-weight: normal;
                }

                .input-row input:focus {
                    border-bottom: 2px solid #d81b21;
                }

        .btn-connect {
            background-color: #d81b21;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 12px 35px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(216, 27, 33, 0.5);
            transition: background-color 0.3s;
        }

            .btn-connect:hover {
                background-color: #b5151b;
            }

        .error-msg {
            color: #ffcccc;
            font-size: 14px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body class="highlands-splash">

    <div class="lang-toggle">VN | EN</div>

    <div class="login-overlay-box">
        <div class="instruction-text">
            Vui lòng nhập số điện thoại để nhận mã OTP<br />và kết nối WiFi miễn phí.
        </div>

        <form asp-controller="Auth" asp-action="SendOtp" method="post">

            <div class="input-row">
                <label for="phone">Số điện thoại:</label>
                <input type="tel"
                       id="phone"
                       name="phone"
                       placeholder="xxxx"
                       required
                       pattern="[0-9]{10}"
                       autocomplete="off" />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">@ViewBag.Error</div>
            }

            <button type="submit" class="btn-connect">Gửi mã OTP</button>
        </form>
    </div>

    <div class="footer-copy">© 2026 Highlands Coffee.</div>

</body>
</html>