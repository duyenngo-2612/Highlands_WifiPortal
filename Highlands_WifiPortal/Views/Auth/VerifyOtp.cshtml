@{
    Layout = null;
    // Có thể nhận số điện thoại từ TempData hoặc ViewBag để hiển thị lại cho người dùng
    var phoneNumber = TempData["PhoneNumber"]?.ToString() ?? "số điện thoại của bạn";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác nhận OTP - Highlands Coffee</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="captive-portal">
    <div class="wifi-card">
        <img src="~/images/highlands-logo.png" alt="Highlands Coffee Logo" class="brand-logo" />

        <h2>Xác thực kết nối</h2>
        <p class="text-muted">Mã OTP gồm 6 chữ số đã được gửi đến <strong>@phoneNumber</strong>. Vui lòng kiểm tra tin nhắn.</p>

        <form asp-controller="Auth" asp-action="VerifyOtp" method="post">
            <input type="hidden" name="phoneNumber" value="@phoneNumber" />
            <div class="form-group">
                <input type="text"
                       name="otpCode"
                       class="form-control text-center"
                       placeholder="• • • • • •"
                       required
                       maxlength="6"
                       pattern="[0-9]{6}"
                       autocomplete="one-time-code" />
            </div>
            <button type="submit" class="btn-primary">XÁC NHẬN KẾT NỐI</button>
        </form>
    </div>
</body>
</html>